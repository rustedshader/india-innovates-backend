digraph architecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, shape=box, rounded=true];
    edge [fontname="Helvetica", fontsize=9];
    bgcolor="white";
    pad=0.5;
    nodesep=0.6;
    ranksep=0.8;

    // в”Ђв”Ђ Data Sources в”Ђв”Ђ
    subgraph cluster_sources {
        label="Data Sources";
        style=dashed;
        color="#888888";
        fontcolor="#555555";
        rss [label="RSS Feeds\n(TOI, NDTV, Hindu,\nET, Livemint, ...)", fillcolor="#E3F2FD", color="#1565C0"];
        openmeteo [label="Open-Meteo API\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nForecast (7-day)\nArchive (1940вЂ“present)\nClimate (30-yr normals)\nFree, no API key", fillcolor="#E3F2FD", color="#1565C0"];
    }

    // в”Ђв”Ђ Infrastructure в”Ђв”Ђ
    redis [label="Redis\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nSeen-URL set\n(cross-process dedup)\nSISMEMBER / SADD\nLive-feed pub/sub", fillcolor="#FFEBEE", color="#D32F2F", shape=cylinder];

    kafka [label="Kafka Topic\n(india-innovates)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nArticle JSON messages\nDecouples scraping\nfrom processing", fillcolor="#E8EAF6", color="#283593", shape=cylinder];

    // в”Ђв”Ђ Producer в”Ђв”Ђ
    subgraph cluster_producer {
        label="  PRODUCER  (scheduler/producer.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E8F5E9";
        color="#2E7D32";
        fontcolor="#1B5E20";

        scraper [label="Scraper\n(news_rss.py)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nFetch RSS + full text\nTitle-based dedup\nmax_per_feed limiter", fillcolor="#C8E6C9", color="#2E7D32"];
        publisher [label="Kafka Publisher\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nRedis dedup check\nJSON serialize\nacks=all, retries=3", fillcolor="#C8E6C9", color="#2E7D32"];
    }

    // в”Ђв”Ђ Consumer в”Ђв”Ђ
    subgraph cluster_consumer {
        label="  CONSUMER  (scheduler/consumer.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFFDE7";
        color="#F9A825";
        fontcolor="#E65100";

        batch_acc [label="Batch Accumulator\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nMax 50 articles\nor 60s timeout\nManual offset commit", fillcolor="#FFF9C4", color="#F9A825"];
    }

    // в”Ђв”Ђ Extraction Agent в”Ђв”Ђ
    subgraph cluster_extraction {
        label="  Extraction Agent (per article)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFF8E1";
        color="#F9A825";
        fontcolor="#E65100";

        gliner [label="Phase A: GLiNER2 (205M)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў NER в†’ 9 entity types\nвЂў RE в†’ 26 relation types\nвЂў ~50ms/article, CPU\nвЂў Text-span grounded\nвЂў Confidence scores per entity", fillcolor="#FFF3E0", color="#EF6C00", shape=box];
        canon  [label="Phase B: LLM Canonicalization\n+ Type Correction\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Raw spans в†’ canonical names\nвЂў Generate aliases\nвЂў Confidence < 0.8 в†’ verify type\nвЂў ~500 tokens, lightweight\nвЂў 3-attempt retry", fillcolor="#FFF3E0", color="#EF6C00", shape=box];
        enrich [label="Phase C: LLM Enrichment\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Causal flag classification\nвЂў Temporal marker attachment\nвЂў Event extraction (max 5)", fillcolor="#FFF3E0", color="#EF6C00", shape=box];

        gliner -> canon [label="entities w/ confidence\n+ relations", color="#E65100", fontcolor="#E65100"];
        canon -> enrich [label="canonicalized\nentities + rels", color="#E65100", fontcolor="#E65100"];
    }

    // в”Ђв”Ђ Resolution Agent в”Ђв”Ђ
    subgraph cluster_resolution {
        label="  Resolution Agent (cross-article)  ";
        labeljust=l;
        style=filled;
        fillcolor="#F3E5F5";
        color="#7B1FA2";
        fontcolor="#4A148C";

        tier1 [label="Tier 1: Deterministic\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Alias table (Postgres)\nвЂў Acronym expansion\nвЂў LLM-provided aliases\nвЂў O(N), no LLM", fillcolor="#F8EAF6", color="#7B1FA2"];
        tier2 [label="Tier 2: Embeddings\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў all-MiniLM-L6-v2\nвЂў Type-blocked similarity\nвЂў >0.95 в†’ auto-merge\nвЂў O(N log N), no LLM", fillcolor="#F8EAF6", color="#7B1FA2"];
        tier3 [label="Tier 3: LLM Disambiguation\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Ambiguous pairs (0.80-0.95)\nвЂў Batch 20 pairs per call\nвЂў O(K), K в‰Є N", fillcolor="#F8EAF6", color="#7B1FA2"];

        tier1 -> tier2 [color="#7B1FA2"];
        tier2 -> tier3 [label="candidates\n(sim 0.80-0.95)", color="#7B1FA2", fontcolor="#4A148C"];
    }

    // в”Ђв”Ђ Merge Table в”Ђв”Ђ
    merge_table [label="Persistent Merge Table\n(Postgres: entity_alias)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ntyped + untyped aliases\nO(1) lookup", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // в”Ђв”Ђ Article Storage в”Ђв”Ђ
    article_db [label="Article Storage\n(Postgres: scraped_article)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nURL dedup + full_text\nUsed by Chat + Report Agents", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // в”Ђв”Ђ Weight Cache в”Ђв”Ђ
    weight_cache [label="Domain Weight Cache\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n1 row/domain/day\nLLM-generated weights\nEntity + relation scores", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // в”Ђв”Ђ Report Storage в”Ђв”Ђ
    report_db [label="Domain Reports\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nJSON report storage\nPer domain + date range", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // в”Ђв”Ђ Weather Storage в”Ђв”Ђ
    weather_obs_db [label="Weather Observations\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n25 cities Г— daily\n16 weather vars + z-scores\nUpsert by (city, date)", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];
    weather_anomaly_db [label="Weather Anomalies\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nHeat/cold wave, drought\nExtreme rain, cyclone proxy\nSeverity + z-score", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];
    climate_normals_db [label="Climate Normals\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n30-yr monthly baselines\nmean, std, percentiles\nPer city Г— variable", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // в”Ђв”Ђ Temporal Agent в”Ђв”Ђ
    temporal [label="Temporal Agent (stub)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Logs temporal markers\nвЂў Passthrough\nвЂў State tracking planned", fillcolor="#E8EAF6", color="#283593"];

    // в”Ђв”Ђ Neo4j Save в”Ђв”Ђ
    neo4j_save [label="Batched Neo4j Writer\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n6 UNWIND queries per batch\nWeighted avg confidence\nevidence_count tracking", fillcolor="#FFCDD2", color="#C62828"];

    // в”Ђв”Ђ Storage в”Ђв”Ђ
    neo4j [label="Neo4j Graph DB\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nEntity, Event, Article\nnodes + RELATES_TO,\nINVOLVED_IN, EVIDENCES", fillcolor="#FCE4EC", color="#C62828", shape=cylinder];

    // в”Ђв”Ђ Weather Pipeline в”Ђв”Ђ
    subgraph cluster_weather {
        label="  WEATHER PRODUCER  (scheduler/weather_producer.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E0F2F1";
        color="#00695C";
        fontcolor="#004D40";

        weather_scraper [label="WeatherScraper\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў fetch_historical()\nвЂў fetch_forecast()\nвЂў fetch_climate_normals()\nвЂў 25 Indian cities\nвЂў EC_Earth3P_HR model", fillcolor="#B2DFDB", color="#00695C"];
        anomaly_detector [label="WeatherAnomalyDetector\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Heat wave (40В°C / 3 days)\nвЂў Cold wave (4В°C / 3 days)\nвЂў Extreme rain (204.5mm/day)\nвЂў Drought (compound index)\nвЂў Cyclone proxy (90km/h+rain)\nвЂў Z-score computation", fillcolor="#B2DFDB", color="#00695C"];
        trend_analyzer [label="WeatherTrendAnalyzer\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Annual trend (linregress)\nвЂў Monsoon analysis (Jun-Sep)\nвЂў Extreme frequency tracking", fillcolor="#B2DFDB", color="#00695C"];

        weather_scraper -> anomaly_detector [label="daily DataFrame\n+ normals", color="#00695C", fontcolor="#004D40"];
        weather_scraper -> trend_analyzer [label="historical\nDataFrame", color="#00695C", fontcolor="#004D40"];
    }

    // в”Ђв”Ђ Report Generation Pipeline в”Ђв”Ђ
    subgraph cluster_reports {
        label="  Report Generation (scheduler/report_scheduler.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E8F5E9";
        color="#2E7D32";
        fontcolor="#1B5E20";

        orchestrator [label="ReportOrchestrator\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n4-agent pipeline\nPer domain, hourly\nGraceful degradation", fillcolor="#C8E6C9", color="#2E7D32"];

        subgraph cluster_report_agents {
            label="  Agents  ";
            style=filled;
            fillcolor="#DCEDC8";
            color="#558B2F";
            fontcolor="#33691E";

            weight_gen [label="Stage 0: Dynamic Weights\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Sample graph types\nвЂў LLM scores relevance\nвЂў Cached in Postgres (24h)\nвЂў Cypher map lookups", fillcolor="#F1F8E9", color="#558B2F"];
            report_agent [label="Step 1: ReportAgent\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Scored entity query\nвЂў Fetch articles\nвЂў LLM: DomainBriefing", fillcolor="#F1F8E9", color="#558B2F"];
            india_agent [label="Step 2: IndiaImpactAgent\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Graph traversal from India\nвЂў Subgraph + article filter\nвЂў LLM: strategic assessment", fillcolor="#F1F8E9", color="#558B2F"];
            inference_agent [label="Step 3: InferenceAgent\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Causal chains (Cypher)\nвЂў Impact propagation (BFS)\nвЂў Weak links (bridges)\nвЂў LLM: narratives", fillcolor="#F1F8E9", color="#558B2F"];

            weight_gen -> report_agent [label="weights", color="#558B2F", fontcolor="#33691E"];
            report_agent -> india_agent [label="ReportResult", color="#558B2F", fontcolor="#33691E"];
            india_agent -> inference_agent [label="+ IndiaImpact", color="#558B2F", fontcolor="#33691E"];
        }

        orchestrator -> weight_gen [color="#2E7D32"];
    }

    // в”Ђв”Ђ API в”Ђв”Ђ
    subgraph cluster_api {
        label="  FastAPI Backend (main.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E0F7FA";
        color="#00838F";
        fontcolor="#006064";

        api_graph [label="/api/graph\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nServer-side filtering\nTop-N by degree\nBatched source queries", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_stats [label="/api/graph/stats\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nAggregate counts\nBy entity type", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_chat  [label="/api/chat\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nConversational Q&A\nRetry w/ backoff", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_reports [label="/api/reports\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nDomain briefings\n+ India impact\n+ inference", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_live [label="/api/live-feed\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nSSE + WebSocket\nRedis pub/sub", fillcolor="#B2EBF2", color="#00838F", shape=box];

        api_weather [label="/api/weather/*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ncities | current\ntrends | anomalies\nmonsoon | climate-trends", fillcolor="#B2EBF2", color="#00838F", shape=box];
    }

    // в”Ђв”Ђ Chat Agent (LangGraph) в”Ђв”Ђ
    subgraph cluster_chat {
        label="  Chat Agent (LangGraph)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFF3E0";
        color="#E65100";
        fontcolor="#BF360C";

        router [label="Router\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nDirect / Graph?", fillcolor="#FFE0B2", color="#E65100", shape=diamond];
        cypher_gen [label="Cypher Generator\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nNL в†’ Cypher query\nSchema-aware prompts\nStructured JSON output", fillcolor="#FFE0B2", color="#E65100"];
        cypher_exec [label="Cypher Executor\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nRun on Neo4j\nNeighborhood enrichment\nSafety guards", fillcolor="#FFE0B2", color="#E65100"];
        fetch_articles [label="Fetch Articles\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nPostgres full_text\nMax 5 articles\n2000 chars each", fillcolor="#FFE0B2", color="#E65100"];
        synthesize [label="Synthesizer\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nGraph + article data\nв†’ intelligence briefing", fillcolor="#FFE0B2", color="#E65100"];
        direct [label="Direct Answer\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nGreetings, meta\nquestions", fillcolor="#FFE0B2", color="#E65100"];

        router -> cypher_gen [label="graph", color="#E65100", fontcolor="#BF360C"];
        router -> direct [label="direct", color="#E65100", fontcolor="#BF360C"];
        cypher_gen -> cypher_exec [color="#E65100"];
        cypher_exec -> fetch_articles [color="#E65100"];
        fetch_articles -> synthesize [color="#E65100"];
    }

    // в”Ђв”Ђ Frontend в”Ђв”Ђ
    subgraph cluster_frontend {
        label="  Frontend  ";
        labeljust=l;
        style=filled;
        fillcolor="#ECEFF1";
        color="#37474F";
        fontcolor="#263238";

        viz [label="Graph Visualization\n(vis-network.js)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nFilter toolbar\nSearch + type filter\nNode limit + min connections\nType-colored nodes", fillcolor="#CFD8DC", color="#37474F", shape=box];
        chat_ui [label="Chat Interface\n(/chat)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nConversational Q&A\nCypher display\nConversation history", fillcolor="#CFD8DC", color="#37474F", shape=box];
    }

    // в”Ђв”Ђ LLM Provider в”Ђв”Ђ
    groq [label="Groq API\n(openai/gpt-oss-20b)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nStructured output\n(json_schema mode)\nRetry w/ backoff", fillcolor="#FFFDE7", color="#F57F17", shape=box3d];

    // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    // в”Ђв”Ђ Edges в”Ђв”Ђ
    // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

    // Producer flow
    rss -> scraper [label="URLs", color="#555555"];
    scraper -> publisher [label="list[Article]", color="#2E7D32"];
    publisher -> redis [label="SISMEMBER\n(dedup check)", color="#D32F2F", fontcolor="#D32F2F", style=dashed, dir=both];
    publisher -> kafka [label="article JSON", color="#283593", fontcolor="#283593"];

    // Consumer flow
    kafka -> batch_acc [label="consume\n(batched)", color="#283593", fontcolor="#283593"];
    batch_acc -> gliner [label="list[Article]", color="#555555"];

    // Extraction в†’ Resolution
    enrich -> tier1 [label="list[ArticleExtraction]", color="#555555"];

    // Resolution в†” merge table
    tier1 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    tier2 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    tier3 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed];

    // Resolution в†’ Temporal в†’ Save в†’ Neo4j
    tier3 -> temporal [label="resolved extractions", color="#555555"];
    temporal -> neo4j_save [label="extractions\n(passthrough)", color="#555555"];
    neo4j_save -> neo4j [label="6 UNWIND\nqueries", color="#C62828", fontcolor="#C62828"];
    neo4j_save -> article_db [label="save articles", color="#00695C", fontcolor="#00695C"];

    // Report pipeline в†” data stores
    report_agent -> neo4j [label="scored\nCypher query", color="#C62828", fontcolor="#C62828", style=dashed];
    report_agent -> article_db [label="fetch\narticles", color="#00695C", fontcolor="#00695C", style=dashed];
    weight_gen -> weight_cache [label="cache/read\nweights", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    india_agent -> neo4j [label="India\ntraversal", color="#C62828", fontcolor="#C62828", style=dashed];
    inference_agent -> neo4j [label="chain/impact\nqueries", color="#C62828", fontcolor="#C62828", style=dashed];
    inference_agent -> report_db [label="merged\nreport", color="#00695C", fontcolor="#00695C", style=dashed];

    // API в†” Neo4j
    neo4j -> api_graph [label="filtered\nsubgraph", color="#555555"];
    neo4j -> api_stats [label="counts", color="#555555"];
    api_graph -> viz [color="#555555"];
    api_stats -> viz [style=dashed, color="#555555"];
    api_reports -> report_db [label="fetch\nreports", color="#00695C", fontcolor="#00695C", style=dashed];
    api_live -> redis [label="pub/sub", color="#D32F2F", fontcolor="#D32F2F", style=dashed];

    // Chat flow
    api_chat -> router [label="question +\nhistory", color="#E65100", fontcolor="#BF360C"];
    cypher_exec -> neo4j [label="Cypher\nquery", color="#C62828", fontcolor="#C62828", style=dashed];
    fetch_articles -> article_db [label="full_text\nlookup", color="#00695C", fontcolor="#00695C", style=dashed];
    synthesize -> api_chat [label="answer", color="#E65100", fontcolor="#BF360C", style=dashed];
    direct -> api_chat [label="answer", color="#E65100", fontcolor="#BF360C", style=dashed];
    api_chat -> chat_ui [color="#555555"];

    // Weather pipeline edges
    openmeteo -> weather_scraper [label="REST API\n(3 endpoints)", color="#1565C0", fontcolor="#1565C0"];
    anomaly_detector -> weather_obs_db [label="upsert obs\n+ z-scores", color="#00695C", fontcolor="#00695C", style=dashed];
    anomaly_detector -> weather_anomaly_db [label="save\nanomalies", color="#00695C", fontcolor="#00695C", style=dashed];
    weather_scraper -> climate_normals_db [label="save\nnormals", color="#00695C", fontcolor="#00695C", style=dashed];
    climate_normals_db -> anomaly_detector [label="load\nnormals", color="#00695C", fontcolor="#00695C", style=dashed];
    anomaly_detector -> redis [label="publish\nalerts", color="#D32F2F", fontcolor="#D32F2F", style=dashed];
    api_weather -> weather_obs_db [label="query obs", color="#00695C", fontcolor="#00695C", style=dashed];
    api_weather -> weather_anomaly_db [label="query\nanomalies", color="#00695C", fontcolor="#00695C", style=dashed];
    api_weather -> climate_normals_db [label="query\nnormals", color="#00695C", fontcolor="#00695C", style=dashed];

    // LLM connections
    canon -> groq [style=dashed, color="#F57F17", dir=both];
    enrich -> groq [style=dashed, color="#F57F17", dir=both];
    tier3 -> groq [style=dashed, color="#F57F17", dir=both];
    cypher_gen -> groq [style=dashed, color="#F57F17", dir=both];
    synthesize -> groq [style=dashed, color="#F57F17", dir=both];
    router -> groq [style=dashed, color="#F57F17", dir=both];
    weight_gen -> groq [style=dashed, color="#F57F17", dir=both];
    report_agent -> groq [style=dashed, color="#F57F17", dir=both];
    india_agent -> groq [style=dashed, color="#F57F17", dir=both];
    inference_agent -> groq [style=dashed, color="#F57F17", dir=both];

    // в”Ђв”Ђ Legend в”Ђв”Ђ
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor="#FAFAFA";
        color="#CCCCCC";
        fontsize=10;

        node [shape=plaintext, fillcolor="#FAFAFA", fontsize=9];
        l1  [label="рџџ   Extraction (per article)"];
        l2  [label="рџџЈ  Resolution (cross-article)"];
        l3  [label="рџ”µ  Temporal Agent (stub)"];
        l4  [label="рџџў  Report Pipeline (4 agents)"];
        l5  [label="рџ”ґ  Neo4j Graph DB + Writer"];
        l6  [label="рџџЎ  LLM Provider (Groq)"];
        l7  [label="рџ”·  Chat Agent (LangGraph)"];
        l8  [label="рџ”¶  Kafka Pipeline"];
        l9  [label="рџ”є  Redis (dedup + pub/sub + alerts)"];
        l10 [label="рџџ©  Postgres (articles, weights, reports)"];
        l11 [label="рџЊ¦  Weather Pipeline (Open-Meteo в†’ anomaly detection)"];

        l1 -> l2 -> l3 -> l4 -> l5 -> l6 -> l7 -> l8 -> l9 -> l10 -> l11 [style=invis];
    }
}
