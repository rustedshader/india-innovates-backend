digraph architecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, shape=box, rounded=true];
    edge [fontname="Helvetica", fontsize=9];
    bgcolor="white";
    pad=0.5;
    nodesep=0.6;
    ranksep=0.8;

    // ── Data Sources ──
    subgraph cluster_sources {
        label="Data Sources";
        style=dashed;
        color="#888888";
        fontcolor="#555555";
        rss [label="RSS Feeds\n(TOI, NDTV, Hindu,\nET, Livemint, ...)", fillcolor="#E3F2FD", color="#1565C0"];
    }

    // ── Infrastructure ──
    redis [label="Redis\n━━━━━━━━━━━━━━━━━\nSeen-URL set\n(cross-process dedup)\nSISMEMBER / SADD\nLive-feed pub/sub", fillcolor="#FFEBEE", color="#D32F2F", shape=cylinder];

    kafka [label="Kafka Topic\n(india-innovates)\n━━━━━━━━━━━━━━━━━\nArticle JSON messages\nDecouples scraping\nfrom processing", fillcolor="#E8EAF6", color="#283593", shape=cylinder];

    // ── Producer ──
    subgraph cluster_producer {
        label="  PRODUCER  (scheduler/producer.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E8F5E9";
        color="#2E7D32";
        fontcolor="#1B5E20";

        scraper [label="Scraper\n(news_rss.py)\n━━━━━━━━━━━━━━━━━\nFetch RSS + full text\nTitle-based dedup\nmax_per_feed limiter", fillcolor="#C8E6C9", color="#2E7D32"];
        publisher [label="Kafka Publisher\n━━━━━━━━━━━━━━━━━\nRedis dedup check\nJSON serialize\nacks=all, retries=3", fillcolor="#C8E6C9", color="#2E7D32"];
    }

    // ── Consumer ──
    subgraph cluster_consumer {
        label="  CONSUMER  (scheduler/consumer.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFFDE7";
        color="#F9A825";
        fontcolor="#E65100";

        batch_acc [label="Batch Accumulator\n━━━━━━━━━━━━━━━━━\nMax 50 articles\nor 60s timeout\nManual offset commit", fillcolor="#FFF9C4", color="#F9A825"];
    }

    // ── Extraction Agent ──
    subgraph cluster_extraction {
        label="  Extraction Agent (per article)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFF8E1";
        color="#F9A825";
        fontcolor="#E65100";

        gliner [label="Phase A: GLiNER2 (205M)\n━━━━━━━━━━━━━━━━━━━\n• NER → 9 entity types\n• RE → 26 relation types\n• ~50ms/article, CPU\n• Text-span grounded\n• Confidence scores per entity", fillcolor="#FFF3E0", color="#EF6C00", shape=box];
        canon  [label="Phase B: LLM Canonicalization\n+ Type Correction\n━━━━━━━━━━━━━━━━━━━━━━━━\n• Raw spans → canonical names\n• Generate aliases\n• Confidence < 0.8 → verify type\n• ~500 tokens, lightweight\n• 3-attempt retry", fillcolor="#FFF3E0", color="#EF6C00", shape=box];
        enrich [label="Phase C: LLM Enrichment\n━━━━━━━━━━━━━━━━━━━━━\n• Causal flag classification\n• Temporal marker attachment\n• Event extraction (max 5)", fillcolor="#FFF3E0", color="#EF6C00", shape=box];

        gliner -> canon [label="entities w/ confidence\n+ relations", color="#E65100", fontcolor="#E65100"];
        canon -> enrich [label="canonicalized\nentities + rels", color="#E65100", fontcolor="#E65100"];
    }

    // ── Resolution Agent ──
    subgraph cluster_resolution {
        label="  Resolution Agent (cross-article)  ";
        labeljust=l;
        style=filled;
        fillcolor="#F3E5F5";
        color="#7B1FA2";
        fontcolor="#4A148C";

        tier1 [label="Tier 1: Deterministic\n━━━━━━━━━━━━━━━━━━━\n• Alias table (Postgres)\n• Acronym expansion\n• LLM-provided aliases\n• O(N), no LLM", fillcolor="#F8EAF6", color="#7B1FA2"];
        tier2 [label="Tier 2: Embeddings\n━━━━━━━━━━━━━━━━━━\n• all-MiniLM-L6-v2\n• Type-blocked similarity\n• >0.95 → auto-merge\n• O(N log N), no LLM", fillcolor="#F8EAF6", color="#7B1FA2"];
        tier3 [label="Tier 3: LLM Disambiguation\n━━━━━━━━━━━━━━━━━━━━━━━\n• Ambiguous pairs (0.80-0.95)\n• Batch 20 pairs per call\n• O(K), K ≪ N", fillcolor="#F8EAF6", color="#7B1FA2"];

        tier1 -> tier2 [color="#7B1FA2"];
        tier2 -> tier3 [label="candidates\n(sim 0.80-0.95)", color="#7B1FA2", fontcolor="#4A148C"];
    }

    // ── Merge Table ──
    merge_table [label="Persistent Merge Table\n(Postgres: entity_alias)\n━━━━━━━━━━━━━━━━━━━━━\ntyped + untyped aliases\nO(1) lookup", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // ── Article Storage ──
    article_db [label="Article Storage\n(Postgres: scraped_article)\n━━━━━━━━━━━━━━━━━━━━━\nURL dedup + full_text\nUsed by Chat + Report Agents", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // ── Weight Cache ──
    weight_cache [label="Domain Weight Cache\n(Postgres)\n━━━━━━━━━━━━━━━━━━━━━\n1 row/domain/day\nLLM-generated weights\nEntity + relation scores", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // ── Report Storage ──
    report_db [label="Domain Reports\n(Postgres)\n━━━━━━━━━━━━━━━━━━━━━\nJSON report storage\nPer domain + date range", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // ── Temporal Agent ──
    temporal [label="Temporal Agent (stub)\n━━━━━━━━━━━━━━━━━\n• Logs temporal markers\n• Passthrough\n• State tracking planned", fillcolor="#E8EAF6", color="#283593"];

    // ── Neo4j Save ──
    neo4j_save [label="Batched Neo4j Writer\n━━━━━━━━━━━━━━━━━━━\n6 UNWIND queries per batch\nWeighted avg confidence\nevidence_count tracking", fillcolor="#FFCDD2", color="#C62828"];

    // ── Storage ──
    neo4j [label="Neo4j Graph DB\n━━━━━━━━━━━━━━━━━\nEntity, Event, Article\nnodes + RELATES_TO,\nINVOLVED_IN, EVIDENCES", fillcolor="#FCE4EC", color="#C62828", shape=cylinder];

    // ── Report Generation Pipeline ──
    subgraph cluster_reports {
        label="  Report Generation (scheduler/report_scheduler.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E8F5E9";
        color="#2E7D32";
        fontcolor="#1B5E20";

        orchestrator [label="ReportOrchestrator\n━━━━━━━━━━━━━━━━━━\n4-agent pipeline\nPer domain, hourly\nGraceful degradation", fillcolor="#C8E6C9", color="#2E7D32"];

        subgraph cluster_report_agents {
            label="  Agents  ";
            style=filled;
            fillcolor="#DCEDC8";
            color="#558B2F";
            fontcolor="#33691E";

            weight_gen [label="Stage 0: Dynamic Weights\n━━━━━━━━━━━━━━━━━━━━━━\n• Sample graph types\n• LLM scores relevance\n• Cached in Postgres (24h)\n• Cypher map lookups", fillcolor="#F1F8E9", color="#558B2F"];
            report_agent [label="Step 1: ReportAgent\n━━━━━━━━━━━━━━━━━━━━\n• Scored entity query\n• Fetch articles\n• LLM: DomainBriefing", fillcolor="#F1F8E9", color="#558B2F"];
            india_agent [label="Step 2: IndiaImpactAgent\n━━━━━━━━━━━━━━━━━━━━━━━\n• Graph traversal from India\n• Subgraph + article filter\n• LLM: strategic assessment", fillcolor="#F1F8E9", color="#558B2F"];
            inference_agent [label="Step 3: InferenceAgent\n━━━━━━━━━━━━━━━━━━━━━━━\n• Causal chains (Cypher)\n• Impact propagation (BFS)\n• Weak links (bridges)\n• LLM: narratives", fillcolor="#F1F8E9", color="#558B2F"];

            weight_gen -> report_agent [label="weights", color="#558B2F", fontcolor="#33691E"];
            report_agent -> india_agent [label="ReportResult", color="#558B2F", fontcolor="#33691E"];
            india_agent -> inference_agent [label="+ IndiaImpact", color="#558B2F", fontcolor="#33691E"];
        }

        orchestrator -> weight_gen [color="#2E7D32"];
    }

    // ── API ──
    subgraph cluster_api {
        label="  FastAPI Backend (main.py)  ";
        labeljust=l;
        style=filled;
        fillcolor="#E0F7FA";
        color="#00838F";
        fontcolor="#006064";

        api_graph [label="/api/graph\n━━━━━━━━━━━━\nServer-side filtering\nTop-N by degree\nBatched source queries", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_stats [label="/api/graph/stats\n━━━━━━━━━━━━\nAggregate counts\nBy entity type", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_chat  [label="/api/chat\n━━━━━━━━━━━━\nConversational Q&A\nRetry w/ backoff", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_reports [label="/api/reports\n━━━━━━━━━━━━\nDomain briefings\n+ India impact\n+ inference", fillcolor="#B2EBF2", color="#00838F", shape=box];
        api_live [label="/api/live-feed\n━━━━━━━━━━━━\nSSE + WebSocket\nRedis pub/sub", fillcolor="#B2EBF2", color="#00838F", shape=box];
    }

    // ── Chat Agent (LangGraph) ──
    subgraph cluster_chat {
        label="  Chat Agent (LangGraph)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFF3E0";
        color="#E65100";
        fontcolor="#BF360C";

        router [label="Router\n━━━━━━━━\nDirect / Graph?", fillcolor="#FFE0B2", color="#E65100", shape=diamond];
        cypher_gen [label="Cypher Generator\n━━━━━━━━━━━━━━━━━\nNL → Cypher query\nSchema-aware prompts\nStructured JSON output", fillcolor="#FFE0B2", color="#E65100"];
        cypher_exec [label="Cypher Executor\n━━━━━━━━━━━━━━━━━\nRun on Neo4j\nNeighborhood enrichment\nSafety guards", fillcolor="#FFE0B2", color="#E65100"];
        fetch_articles [label="Fetch Articles\n━━━━━━━━━━━━━━━━━\nPostgres full_text\nMax 5 articles\n2000 chars each", fillcolor="#FFE0B2", color="#E65100"];
        synthesize [label="Synthesizer\n━━━━━━━━━━━━━\nGraph + article data\n→ intelligence briefing", fillcolor="#FFE0B2", color="#E65100"];
        direct [label="Direct Answer\n━━━━━━━━━━━━━\nGreetings, meta\nquestions", fillcolor="#FFE0B2", color="#E65100"];

        router -> cypher_gen [label="graph", color="#E65100", fontcolor="#BF360C"];
        router -> direct [label="direct", color="#E65100", fontcolor="#BF360C"];
        cypher_gen -> cypher_exec [color="#E65100"];
        cypher_exec -> fetch_articles [color="#E65100"];
        fetch_articles -> synthesize [color="#E65100"];
    }

    // ── Frontend ──
    subgraph cluster_frontend {
        label="  Frontend  ";
        labeljust=l;
        style=filled;
        fillcolor="#ECEFF1";
        color="#37474F";
        fontcolor="#263238";

        viz [label="Graph Visualization\n(vis-network.js)\n━━━━━━━━━━━━━━━━━━━\nFilter toolbar\nSearch + type filter\nNode limit + min connections\nType-colored nodes", fillcolor="#CFD8DC", color="#37474F", shape=box];
        chat_ui [label="Chat Interface\n(/chat)\n━━━━━━━━━━━━━━━━\nConversational Q&A\nCypher display\nConversation history", fillcolor="#CFD8DC", color="#37474F", shape=box];
    }

    // ── LLM Provider ──
    groq [label="Groq API\n(openai/gpt-oss-20b)\n━━━━━━━━━━━━━━━━━━━\nStructured output\n(json_schema mode)\nRetry w/ backoff", fillcolor="#FFFDE7", color="#F57F17", shape=box3d];

    // ════════════════════════════════
    // ── Edges ──
    // ════════════════════════════════

    // Producer flow
    rss -> scraper [label="URLs", color="#555555"];
    scraper -> publisher [label="list[Article]", color="#2E7D32"];
    publisher -> redis [label="SISMEMBER\n(dedup check)", color="#D32F2F", fontcolor="#D32F2F", style=dashed, dir=both];
    publisher -> kafka [label="article JSON", color="#283593", fontcolor="#283593"];

    // Consumer flow
    kafka -> batch_acc [label="consume\n(batched)", color="#283593", fontcolor="#283593"];
    batch_acc -> gliner [label="list[Article]", color="#555555"];

    // Extraction → Resolution
    enrich -> tier1 [label="list[ArticleExtraction]", color="#555555"];

    // Resolution ↔ merge table
    tier1 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    tier2 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    tier3 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed];

    // Resolution → Temporal → Save → Neo4j
    tier3 -> temporal [label="resolved extractions", color="#555555"];
    temporal -> neo4j_save [label="extractions\n(passthrough)", color="#555555"];
    neo4j_save -> neo4j [label="6 UNWIND\nqueries", color="#C62828", fontcolor="#C62828"];
    neo4j_save -> article_db [label="save articles", color="#00695C", fontcolor="#00695C"];

    // Report pipeline ↔ data stores
    report_agent -> neo4j [label="scored\nCypher query", color="#C62828", fontcolor="#C62828", style=dashed];
    report_agent -> article_db [label="fetch\narticles", color="#00695C", fontcolor="#00695C", style=dashed];
    weight_gen -> weight_cache [label="cache/read\nweights", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    india_agent -> neo4j [label="India\ntraversal", color="#C62828", fontcolor="#C62828", style=dashed];
    inference_agent -> neo4j [label="chain/impact\nqueries", color="#C62828", fontcolor="#C62828", style=dashed];
    inference_agent -> report_db [label="merged\nreport", color="#00695C", fontcolor="#00695C", style=dashed];

    // API ↔ Neo4j
    neo4j -> api_graph [label="filtered\nsubgraph", color="#555555"];
    neo4j -> api_stats [label="counts", color="#555555"];
    api_graph -> viz [color="#555555"];
    api_stats -> viz [style=dashed, color="#555555"];
    api_reports -> report_db [label="fetch\nreports", color="#00695C", fontcolor="#00695C", style=dashed];
    api_live -> redis [label="pub/sub", color="#D32F2F", fontcolor="#D32F2F", style=dashed];

    // Chat flow
    api_chat -> router [label="question +\nhistory", color="#E65100", fontcolor="#BF360C"];
    cypher_exec -> neo4j [label="Cypher\nquery", color="#C62828", fontcolor="#C62828", style=dashed];
    fetch_articles -> article_db [label="full_text\nlookup", color="#00695C", fontcolor="#00695C", style=dashed];
    synthesize -> api_chat [label="answer", color="#E65100", fontcolor="#BF360C", style=dashed];
    direct -> api_chat [label="answer", color="#E65100", fontcolor="#BF360C", style=dashed];
    api_chat -> chat_ui [color="#555555"];

    // LLM connections
    canon -> groq [style=dashed, color="#F57F17", dir=both];
    enrich -> groq [style=dashed, color="#F57F17", dir=both];
    tier3 -> groq [style=dashed, color="#F57F17", dir=both];
    cypher_gen -> groq [style=dashed, color="#F57F17", dir=both];
    synthesize -> groq [style=dashed, color="#F57F17", dir=both];
    router -> groq [style=dashed, color="#F57F17", dir=both];
    weight_gen -> groq [style=dashed, color="#F57F17", dir=both];
    report_agent -> groq [style=dashed, color="#F57F17", dir=both];
    india_agent -> groq [style=dashed, color="#F57F17", dir=both];
    inference_agent -> groq [style=dashed, color="#F57F17", dir=both];

    // ── Legend ──
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor="#FAFAFA";
        color="#CCCCCC";
        fontsize=10;

        node [shape=plaintext, fillcolor="#FAFAFA", fontsize=9];
        l1  [label="🟠  Extraction (per article)"];
        l2  [label="🟣  Resolution (cross-article)"];
        l3  [label="🔵  Temporal Agent (stub)"];
        l4  [label="🟢  Report Pipeline (4 agents)"];
        l5  [label="🔴  Neo4j Graph DB + Writer"];
        l6  [label="🟡  LLM Provider (Groq)"];
        l7  [label="🔷  Chat Agent (LangGraph)"];
        l8  [label="🔶  Kafka Pipeline"];
        l9  [label="🔺  Redis (dedup + pub/sub)"];
        l10 [label="🟩  Postgres (articles, weights, reports)"];

        l1 -> l2 -> l3 -> l4 -> l5 -> l6 -> l7 -> l8 -> l9 -> l10 [style=invis];
    }
}
