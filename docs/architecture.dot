digraph architecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, shape=box, rounded=true];
    edge [fontname="Helvetica", fontsize=9];
    bgcolor="white";
    pad=0.5;
    nodesep=0.6;
    ranksep=0.8;

    // в”Ђв”Ђ Data Sources в”Ђв”Ђ
    subgraph cluster_sources {
        label="Data Sources";
        style=dashed;
        color="#888888";
        fontcolor="#555555";
        rss [label="RSS Feeds\n(TOI, NDTV, Hindu,\nET, Livemint, ...)", fillcolor="#E3F2FD", color="#1565C0"];
    }

    // в”Ђв”Ђ Scraper в”Ђв”Ђ
    scraper [label="Scraper\n(news_rss.py)\nFetch RSS + full text", fillcolor="#E8F5E9", color="#2E7D32"];

    // в”Ђв”Ђ Extraction Agent в”Ђв”Ђ
    subgraph cluster_extraction {
        label="  Extraction Agent (per article)  ";
        labeljust=l;
        style=filled;
        fillcolor="#FFF8E1";
        color="#F9A825";
        fontcolor="#E65100";

        gliner [label="Phase A: GLiNER2 (205M)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў NER в†’ 9 entity types\nвЂў RE в†’ 26 relation types\nвЂў ~50ms/article, CPU\nвЂў Text-span grounded", fillcolor="#FFF3E0", color="#EF6C00", shape=box];
        canon  [label="Phase B: LLM Canonicalization\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Raw spans в†’ canonical names\nвЂў Generate aliases\nвЂў Update relation names\nвЂў ~500 tokens, lightweight", fillcolor="#FFF3E0", color="#EF6C00", shape=box];
        enrich [label="Phase C: LLM Enrichment\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Causal flag classification\nвЂў Temporal marker attachment\nвЂў Event extraction (max 5)", fillcolor="#FFF3E0", color="#EF6C00", shape=box];

        gliner -> canon [label="raw entities\n+ relations", color="#E65100", fontcolor="#E65100"];
        canon -> enrich [label="canonicalized\nentities + rels", color="#E65100", fontcolor="#E65100"];
    }

    // в”Ђв”Ђ Resolution Agent в”Ђв”Ђ
    subgraph cluster_resolution {
        label="  Resolution Agent (cross-article)  ";
        labeljust=l;
        style=filled;
        fillcolor="#F3E5F5";
        color="#7B1FA2";
        fontcolor="#4A148C";

        tier1 [label="Tier 1: Deterministic\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Alias table (Postgres)\nвЂў Substring containment\nвЂў Acronym expansion\nвЂў O(N), no LLM", fillcolor="#F8EAF6", color="#7B1FA2"];
        tier2 [label="Tier 2: Embeddings\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў all-MiniLM-L6-v2\nвЂў Type-blocked similarity\nвЂў >0.95 в†’ auto-merge\nвЂў O(N log N), no LLM", fillcolor="#F8EAF6", color="#7B1FA2"];
        tier3 [label="Tier 3: LLM Disambiguation\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Ambiguous pairs (0.80-0.95)\nвЂў Batch 20 pairs per call\nвЂў O(K), K в‰Є N", fillcolor="#F8EAF6", color="#7B1FA2"];

        tier1 -> tier2 [color="#7B1FA2"];
        tier2 -> tier3 [label="candidates\n(sim 0.80-0.95)", color="#7B1FA2", fontcolor="#4A148C"];
    }

    // в”Ђв”Ђ Merge Table в”Ђв”Ђ
    merge_table [label="Persistent Merge Table\n(Postgres: entity_alias)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ntyped + untyped aliases\nO(1) lookup", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    // в”Ђв”Ђ Temporal Agent в”Ђв”Ђ
    temporal [label="Temporal Agent\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў State tracking\nвЂў Date attachment\nвЂў current vs historical", fillcolor="#E8EAF6", color="#283593"];

    // в”Ђв”Ђ Inference Agent в”Ђв”Ђ
    inference [label="Inference Agent\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Cross-domain causal chains\nвЂў Impact propagation\nвЂў Weak link detection", fillcolor="#E8EAF6", color="#283593"];

    // в”Ђв”Ђ Storage в”Ђв”Ђ
    neo4j [label="Neo4j Graph DB\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nEntity, Event, State,\nArticle nodes\n+ typed relationships", fillcolor="#FCE4EC", color="#C62828", shape=cylinder];

    // в”Ђв”Ђ API в”Ђв”Ђ
    api [label="FastAPI\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n/api/graph\n/api/visualize", fillcolor="#E0F7FA", color="#00838F", shape=box];

    // в”Ђв”Ђ Frontend в”Ђв”Ђ
    viz [label="Visualization\n(D3.js / Deck.gl)", fillcolor="#ECEFF1", color="#37474F", shape=box];

    // в”Ђв”Ђ Edges в”Ђв”Ђ
    rss -> scraper [label="URLs", color="#555555"];
    scraper -> gliner [label="list[Article]", color="#555555"];
    enrich -> tier1 [label="list[ArticleExtraction]", color="#555555"];

    // Resolution в†” merge table
    tier1 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    tier2 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed, dir=both];
    tier3 -> merge_table [label="save\naliases", color="#00695C", fontcolor="#00695C", style=dashed];

    tier3 -> temporal [label="resolved extractions", color="#555555"];
    temporal -> inference [color="#555555"];
    inference -> neo4j [label="write graph", color="#555555"];
    neo4j -> api [label="Cypher queries", color="#555555"];
    api -> viz [color="#555555"];

    // в”Ђв”Ђ Legend в”Ђв”Ђ
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor="#FAFAFA";
        color="#CCCCCC";
        fontsize=10;

        node [shape=plaintext, fillcolor="#FAFAFA", fontsize=9];
        l1 [label="рџџ   Extraction (per article)"];
        l2 [label="рџџЈ  Resolution (cross-article)"];
        l3 [label="рџ”µ  Temporal + Inference"];
        l4 [label="рџџў  Scraper"];
        l5 [label="рџ”ґ  Storage"];

        l1 -> l2 -> l3 -> l4 -> l5 [style=invis];
    }
}
