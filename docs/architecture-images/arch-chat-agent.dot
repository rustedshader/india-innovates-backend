digraph chat_agent {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, shape=box, rounded=true];
    edge [fontname="Helvetica", fontsize=9];
    bgcolor="white";
    pad=0.4;
    nodesep=0.5;
    ranksep=0.7;
    label="Chat Agent — Graph RAG (LangGraph State Machine)";
    labelloc=t;
    fontsize=14;
    fontcolor="#333333";

    // Frontend
    chat_ui [label="React Chat Panel\n━━━━━━━━━━━━━━━━━━━\nMarkdown rendering\nResizable side panel\nConversation history", fillcolor="#CFD8DC", color="#37474F"];

    // Input
    input [label="POST /api/chat\n{question, history[]}", fillcolor="#E3F2FD", color="#1565C0"];

    // Router
    router [label="Router\n━━━━━━━━━━━\nNeeds graph data?\nOr direct answer?", fillcolor="#FFE0B2", color="#E65100", shape=diamond];

    // Graph path
    subgraph cluster_graph_path {
        label="Graph Path";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontcolor="#BF360C";

        cypher_gen [label="Cypher Generator\n━━━━━━━━━━━━━━━━━━━━━\nNL → 1..N Cypher queries\nSchema-aware prompts\nQuery templates\nStructured JSON output", fillcolor="#FFE0B2", color="#E65100"];
        cypher_exec [label="Cypher Executor\n━━━━━━━━━━━━━━━━━━━━━\nRun on Neo4j (read-only)\n25 row limit\nNeighborhood enrichment\nCollect article URLs", fillcolor="#FFE0B2", color="#E65100"];
        fetch_articles [label="Fetch Articles\n━━━━━━━━━━━━━━━━━━━\nPostgres full_text lookup\nMax 5 articles\n2000 chars each", fillcolor="#FFE0B2", color="#E65100"];
        synthesize [label="Synthesizer\n━━━━━━━━━━━━━━━━━━━\nGraph data + article text\n→ Intelligence briefing\nProvenance tracking", fillcolor="#FFE0B2", color="#E65100"];

        cypher_gen -> cypher_exec [color="#E65100"];
        cypher_exec -> fetch_articles [color="#E65100"];
        fetch_articles -> synthesize [color="#E65100"];
    }

    // Direct path
    direct [label="Direct Answer\n━━━━━━━━━━━━━━\nGreetings, meta\nquestions, help", fillcolor="#FFE0B2", color="#E65100"];

    // Output
    output [label="Response\n(answer + cypher + route)", fillcolor="#C8E6C9", color="#2E7D32"];

    // Data stores
    neo4j [label="Neo4j\nGraph DB", fillcolor="#FCE4EC", color="#C62828", shape=cylinder];
    postgres [label="PostgreSQL\n(scraped_articles)", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];
    groq [label="Groq LLM", fillcolor="#FFFDE7", color="#F57F17", shape=box3d];

    // Main flow edges
    chat_ui -> input [label="question +\nhistory", color="#555555"];
    input -> router [color="#555555"];
    router -> cypher_gen [label="graph", color="#E65100"];
    router -> direct [label="direct", color="#E65100"];
    synthesize -> output [color="#2E7D32"];
    direct -> output [color="#2E7D32"];
    output -> chat_ui [label="{answer, cypher}", color="#555555"];

    // Data store edges
    cypher_exec -> neo4j [label="Cypher\nquery", color="#C62828", style=dashed, dir=both];
    fetch_articles -> postgres [label="full_text\nlookup", color="#00695C", style=dashed, dir=both];

    // LLM edges
    router -> groq [style=dashed, color="#F57F17", dir=both];
    cypher_gen -> groq [style=dashed, color="#F57F17", dir=both];
    synthesize -> groq [style=dashed, color="#F57F17", dir=both];
}
