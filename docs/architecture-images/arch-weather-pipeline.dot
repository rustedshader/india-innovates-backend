digraph weather_pipeline {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, shape=box, rounded=true];
    edge [fontname="Helvetica", fontsize=9];
    bgcolor="white";
    pad=0.4;
    nodesep=0.5;
    ranksep=0.7;
    label="Weather Pipeline вЂ” Open-Meteo Ingest + Anomaly Detection (25 Indian Cities)";
    labelloc=t;
    fontsize=14;
    fontcolor="#333333";

    // Source
    openmeteo [label="Open-Meteo API\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nForecast (7-day)\nArchive (1940вЂ“present)\nClimate (30-yr normals)\nFree, no API key", fillcolor="#E3F2FD", color="#1565C0"];

    // Scraper
    subgraph cluster_scraper {
        label="WeatherScraper";
        style=filled; fillcolor="#B2DFDB"; color="#00695C"; fontcolor="#004D40";

        fetch_hist [label="fetch_historical()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nEC_Earth3P_HR model\nDaily observations", fillcolor="#E0F2F1", color="#00695C"];
        fetch_forecast [label="fetch_forecast()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n7-day forecast\n16 weather variables", fillcolor="#E0F2F1", color="#00695C"];
        fetch_normals [label="fetch_climate_normals()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n30-year baselines\n(1991вЂ“2020)", fillcolor="#E0F2F1", color="#00695C"];
    }

    // Anomaly Detector
    subgraph cluster_anomaly {
        label="WeatherAnomalyDetector";
        style=filled; fillcolor="#B2DFDB"; color="#00695C"; fontcolor="#004D40";

        zscore [label="Z-Score Computation\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nPer variable vs\nclimate normals", fillcolor="#E0F2F1", color="#00695C"];
        heat [label="Heat Wave Detection\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nIMD: Tmax > 40В°C\nfor в‰Ґ 3 consecutive days", fillcolor="#FFCDD2", color="#D32F2F"];
        cold [label="Cold Wave Detection\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nIMD: Tmin < 4В°C\nfor в‰Ґ 3 consecutive days", fillcolor="#BBDEFB", color="#1565C0"];
        rain [label="Extreme Rainfall\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nIMD: в‰Ґ 204.5 mm/day", fillcolor="#B3E5FC", color="#0277BD"];
        drought [label="Drought Detection\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nSoil moisture z < -1.5\nfor в‰Ґ 14 days", fillcolor="#FFE0B2", color="#EF6C00"];
        cyclone [label="Cyclone Proxy\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nWind в‰Ґ 90 km/h\n+ sustained rain", fillcolor="#E1BEE7", color="#7B1FA2"];
    }

    // Trend Analyzer
    subgraph cluster_trend {
        label="WeatherTrendAnalyzer";
        style=filled; fillcolor="#B2DFDB"; color="#00695C"; fontcolor="#004D40";

        annual [label="Annual Trend\n(linear regression)", fillcolor="#E0F2F1", color="#00695C"];
        monsoon [label="Monsoon Analysis\n(JunвЂ“Sep rainfall)", fillcolor="#E0F2F1", color="#00695C"];
        extreme_freq [label="Extreme Frequency\nTracking", fillcolor="#E0F2F1", color="#00695C"];
    }

    // Storage
    weather_obs [label="Weather Observations\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n25 cities Г— daily\n16 vars + z-scores", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];
    weather_anom [label="Weather Anomalies\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nHeat/cold wave, drought\nExtreme rain, cyclone\nSeverity + z-score", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];
    climate_db [label="Climate Normals\n(Postgres)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n30-yr monthly baselines\nmean, std, percentiles", fillcolor="#E0F2F1", color="#00695C", shape=cylinder];

    redis [label="Redis\n(weather alerts)", fillcolor="#FFEBEE", color="#D32F2F", shape=cylinder];

    // API
    api [label="API Endpoints\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n/cities  /current\n/trends  /anomalies\n/monsoon", fillcolor="#B2EBF2", color="#00838F"];

    // Edges
    openmeteo -> fetch_hist [label="REST", color="#1565C0"];
    openmeteo -> fetch_forecast [label="REST", color="#1565C0"];
    openmeteo -> fetch_normals [label="REST", color="#1565C0"];

    fetch_hist -> zscore [label="daily DataFrame", color="#00695C"];
    fetch_forecast -> zscore [label="daily DataFrame", color="#00695C"];
    fetch_normals -> climate_db [label="save normals", color="#00695C", style=dashed];
    climate_db -> zscore [label="load normals", color="#00695C", style=dashed];

    zscore -> heat [color="#00695C"];
    zscore -> cold [color="#00695C"];
    zscore -> rain [color="#00695C"];
    zscore -> drought [color="#00695C"];
    zscore -> cyclone [color="#00695C"];

    zscore -> weather_obs [label="upsert obs\n+ z-scores", color="#00695C", style=dashed];
    heat -> weather_anom [color="#00695C", style=dashed];
    cold -> weather_anom [color="#00695C", style=dashed];
    rain -> weather_anom [color="#00695C", style=dashed];
    drought -> weather_anom [color="#00695C", style=dashed];
    cyclone -> weather_anom [color="#00695C", style=dashed];
    heat -> redis [label="alert", color="#D32F2F", style=dashed];

    fetch_hist -> annual [label="historical\nDataFrame", color="#00695C"];
    fetch_hist -> monsoon [color="#00695C"];
    fetch_hist -> extreme_freq [color="#00695C"];

    api -> weather_obs [style=dashed, color="#00695C"];
    api -> weather_anom [style=dashed, color="#00695C"];
    api -> climate_db [style=dashed, color="#00695C"];
}
